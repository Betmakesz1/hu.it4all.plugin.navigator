 org.eclipse.jface,
 org.eclipse.jface.text,
 org.eclipse.text,
 org.eclipse.ui.workbench.texteditor,
 org.eclipse.ltk.core.refactoring,
 org.eclipse.ltk.ui.refactoring,
 com.google.gson
Bundle-RequiredExecutionEnvironment: JavaSE-11
Automatic-Module-Name: org.smartbit4all.eclipse.event
Bundle-ActivationPolicy: lazy
Export-Package: org.smartbit4all.eclipse.event.core,
 org.smartbit4all.eclipse.event.ast,
 org.smartbit4all.eclipse.event.navigation,
 org.smartbit4all.eclipse.event.validation,
 org.smartbit4all.eclipse.event.ui.gutter,
