<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <extension
         point="org.eclipse.jdt.ui.javaElementFilters">
      <!-- TODO: Add Java element filters -->
   </extension>

   <extension
         point="org.eclipse.jdt.core.compilationParticipant">
      <!-- TODO: Add compilation participant for validation -->
   </extension>

   <extension
         point="org.eclipse.jdt.ui.quickFixProcessors">
      <!-- TODO: Add quick fix processor -->
   </extension>

   <extension
         point="org.eclipse.ui.editors.markerAnnotationSpecification">
      <!-- Event Publisher Marker Annotation -->
      <markerAnnotationSpecification
            annotationType="org.smartbit4all.eclipse.event.publisherMarker"
            label="%annotation.eventPublisher.label"
            icon="icons/event_publisher.png"
            iconSet="icons/event_publisher.png"
            quickFixIcon="icons/event_publisher_32.png"
            verticalRulerPreferenceLabel="Event Publisher in Vertical Ruler"
            highlightPreferenceLabel="Highlight Event Publisher"
            highlightPreferenceColor="100,150,200"
            contributesToHeader="true"
            showInNextPrevDropdown="false"
            textPreferenceKey="eventPublisherAnnotationIndication"
            overviewRulerPreferenceKey="eventPublisherAnnotationIndicationInOverviewRuler"
            textStylePreferenceKey="eventPublisherAnnotationIndicationStyle"
            verticalRulerPreferenceKey="eventPublisherAnnotationIndicationInVerticalRuler"
            presentationLayer="2">
      </markerAnnotationSpecification>

      <!-- Event Subscriber Marker Annotation -->
      <markerAnnotationSpecification
            annotationType="org.smartbit4all.eclipse.event.subscriberMarker"
            label="%annotation.eventSubscriber.label"
            icon="icons/event_subscriber.png"
            iconSet="icons/event_subscriber.png"
            quickFixIcon="icons/event_subscriber_32.png"
            verticalRulerPreferenceLabel="Event Subscriber in Vertical Ruler"
            highlightPreferenceLabel="Highlight Event Subscriber"
            highlightPreferenceColor="150,200,100"
            contributesToHeader="true"
            showInNextPrevDropdown="false"
            textPreferenceKey="eventSubscriberAnnotationIndication"
            overviewRulerPreferenceKey="eventSubscriberAnnotationIndicationInOverviewRuler"
            textStylePreferenceKey="eventSubscriberAnnotationIndicationStyle"
            verticalRulerPreferenceKey="eventSubscriberAnnotationIndicationInVerticalRuler"
            presentationLayer="2">
      </markerAnnotationSpecification>

      <!-- Event Warning Marker Annotation -->
      <markerAnnotationSpecification
            annotationType="org.smartbit4all.eclipse.event.warningMarker"
            label="%annotation.eventWarning.label"
            icon="icons/event_warning.png"
            iconSet="icons/event_warning.png"
            quickFixIcon="icons/event_warning.png"
            verticalRulerPreferenceLabel="Event Warning in Vertical Ruler"
            highlightPreferenceLabel="Highlight Event Warning"
            highlightPreferenceColor="255,200,100"
            contributesToHeader="true"
            showInNextPrevDropdown="true"
            textPreferenceKey="eventWarningAnnotationIndication"
            overviewRulerPreferenceKey="eventWarningAnnotationIndicationInOverviewRuler"
            textStylePreferenceKey="eventWarningAnnotationIndicationStyle"
            verticalRulerPreferenceKey="eventWarningAnnotationIndicationInVerticalRuler"
            presentationLayer="3">
      </markerAnnotationSpecification>
   </extension>

   <extension
         point="org.eclipse.ui.workbench.texteditor.hyperlinkDetectors">
      <hyperlinkDetector
            id="org.smartbit4all.eclipse.event.navigation.EventHyperlinkDetector"
            name="Event Navigation Hyperlink Detector"
            description="Enables Ctrl+Click navigation between event publishers and subscribers"
            class="org.smartbit4all.eclipse.event.navigation.EventHyperlinkDetector"
            targetId="org.eclipse.jdt.ui.javaCode"
            priority="500"
            activate="true">
      </hyperlinkDetector>
   </extension>

   <extension
         point="org.eclipse.ui.views">
      <!-- TODO: Add Event Graph View -->
   </extension>

   <extension
         point="org.eclipse.ltk.core.refactoring.refactoringContributions">
      <!-- TODO: Add refactoring contributions -->
   </extension>

   <extension
         point="org.eclipse.jdt.ui.javaCompletionProposalComputer">
      <!-- TODO: Add code completion support -->
   </extension>

   <extension
         point="org.eclipse.ui.preferencePages">
      <page
            id="org.smartbit4all.eclipse.event.preferences.EventPluginPreferencePage"
            name="Event Navigator"
            class="org.smartbit4all.eclipse.event.preferences.EventPluginPreferencePage">
      </page>
   </extension>

   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.smartbit4all.eclipse.event.commands.testEventAnnotationScanner"
            name="%command.testEventAnnotationScanner.name"
            description="%command.testEventAnnotationScanner.desc">
      </command>
      <command
            id="org.smartbit4all.eclipse.event.commands.testEventPublisherScanner"
            name="%command.testEventPublisherScanner.name"
            description="%command.testEventPublisherScanner.desc">
      </command>
      <command
            id="org.smartbit4all.eclipse.event.commands.indexWorkspace"
            name="%command.indexWorkspace.name"
            description="%command.indexWorkspace.desc">
      </command>
   </extension>

   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.smartbit4all.eclipse.event.ui.commands.EventAnnotationTestHandler"
            commandId="org.smartbit4all.eclipse.event.commands.testEventAnnotationScanner">
         <activeWhen>
            <iterate ifEmpty="false">
               <adapt type="org.eclipse.jdt.core.ICompilationUnit"/>
            </iterate>
         </activeWhen>
      </handler>
      <handler
            class="org.smartbit4all.eclipse.event.ui.commands.EventPublisherTestHandler"
            commandId="org.smartbit4all.eclipse.event.commands.testEventPublisherScanner">
         <activeWhen>
            <iterate ifEmpty="false">
               <adapt type="org.eclipse.jdt.core.ICompilationUnit"/>
            </iterate>
         </activeWhen>
      </handler>
      <handler
            class="org.smartbit4all.eclipse.event.ui.commands.IndexWorkspaceHandler"
            commandId="org.smartbit4all.eclipse.event.commands.indexWorkspace">
      </handler>
   </extension>

   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            locationURI="popup:org.eclipse.ui.navigator.ProjectExplorer#PopupMenu">
         <separator
               name="org.smartbit4all.eclipse.event.separator"
               visible="true">
         </separator>
         <command
               commandId="org.smartbit4all.eclipse.event.commands.indexWorkspace"
               label="%command.indexWorkspace.label"
               style="push">
         </command>
         <menu
               id="org.smartbit4all.eclipse.event.menus.testMenu"
               label="%menu.eventNavigationTests.label">
            <command
                  commandId="org.smartbit4all.eclipse.event.commands.testEventAnnotationScanner"
                  label="%command.testEventAnnotationScanner.label"
                  style="push">
            </command>
            <command
                  commandId="org.smartbit4all.eclipse.event.commands.testEventPublisherScanner"
                  label="%command.testEventPublisherScanner.label"
                  style="push">
            </command>
         </menu>
      </menuContribution>
   </extension>

</plugin>

