<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <extension
         point="org.eclipse.jdt.ui.javaElementFilters">
      <!-- TODO: Add Java element filters -->
   </extension>

   <extension
         point="org.eclipse.jdt.core.compilationParticipant">
      <!-- TODO: Add compilation participant for validation -->
   </extension>

   <extension
         point="org.eclipse.jdt.ui.quickFixProcessors">
      <!-- TODO: Add quick fix processor -->
   </extension>

   <extension
         point="org.eclipse.ui.editors.markerAnnotationSpecification">
      <!-- TODO: Add marker annotation specifications for gutter icons -->
   </extension>

   <extension
         point="org.eclipse.ui.workbench.texteditor.hyperlinkDetectors">
      <hyperlinkDetector
            id="org.smartbit4all.eclipse.event.navigation.EventHyperlinkDetector"
            name="Event Navigation Hyperlink Detector"
            description="Enables Ctrl+Click navigation between event publishers and subscribers"
            class="org.smartbit4all.eclipse.event.navigation.EventHyperlinkDetector"
            targetId="org.eclipse.jdt.ui.javaCode"
            priority="500"
            activate="true">
      </hyperlinkDetector>
   </extension>

   <extension
         point="org.eclipse.ui.views">
      <!-- TODO: Add Event Graph View -->
   </extension>

   <extension
         point="org.eclipse.ltk.core.refactoring.refactoringContributions">
      <!-- TODO: Add refactoring contributions -->
   </extension>

   <extension
         point="org.eclipse.jdt.ui.javaCompletionProposalComputer">
      <!-- TODO: Add code completion support -->
   </extension>

   <extension
         point="org.eclipse.ui.preferencePages">
      <!-- TODO: Add preferences page -->
   </extension>

   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.smartbit4all.eclipse.event.commands.testEventAnnotationScanner"
            name="%command.testEventAnnotationScanner.name"
            description="%command.testEventAnnotationScanner.desc">
      </command>
      <command
            id="org.smartbit4all.eclipse.event.commands.testEventPublisherScanner"
            name="%command.testEventPublisherScanner.name"
            description="%command.testEventPublisherScanner.desc">
      </command>
      <command
            id="org.smartbit4all.eclipse.event.commands.indexWorkspace"
            name="%command.indexWorkspace.name"
            description="%command.indexWorkspace.desc">
      </command>
   </extension>

   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.smartbit4all.eclipse.event.ui.commands.EventAnnotationTestHandler"
            commandId="org.smartbit4all.eclipse.event.commands.testEventAnnotationScanner">
         <activeWhen>
            <iterate ifEmpty="false">
               <adapt type="org.eclipse.jdt.core.ICompilationUnit"/>
            </iterate>
         </activeWhen>
      </handler>
      <handler
            class="org.smartbit4all.eclipse.event.ui.commands.EventPublisherTestHandler"
            commandId="org.smartbit4all.eclipse.event.commands.testEventPublisherScanner">
         <activeWhen>
            <iterate ifEmpty="false">
               <adapt type="org.eclipse.jdt.core.ICompilationUnit"/>
            </iterate>
         </activeWhen>
      </handler>
      <handler
            class="org.smartbit4all.eclipse.event.ui.commands.IndexWorkspaceHandler"
            commandId="org.smartbit4all.eclipse.event.commands.indexWorkspace">
      </handler>
   </extension>

   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            locationURI="popup:org.eclipse.ui.navigator.ProjectExplorer#PopupMenu">
         <separator
               name="org.smartbit4all.eclipse.event.separator"
               visible="true">
         </separator>
         <command
               commandId="org.smartbit4all.eclipse.event.commands.indexWorkspace"
               label="%command.indexWorkspace.label"
               style="push">
         </command>
         <menu
               id="org.smartbit4all.eclipse.event.menus.testMenu"
               label="%menu.eventNavigationTests.label">
            <command
                  commandId="org.smartbit4all.eclipse.event.commands.testEventAnnotationScanner"
                  label="%command.testEventAnnotationScanner.label"
                  style="push">
            </command>
            <command
                  commandId="org.smartbit4all.eclipse.event.commands.testEventPublisherScanner"
                  label="%command.testEventPublisherScanner.label"
                  style="push">
            </command>
         </menu>
      </menuContribution>
   </extension>

</plugin>

